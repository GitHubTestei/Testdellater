-- =============================================
-- GUI Dragging (title bar only)
-- =============================================
local isDraggingGui = false
local dragInput, dragStart, startPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingGui = true
        dragStart = input.Position
        startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                isDraggingGui = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        activeSlider = nil
    end
end)

RunService.RenderStepped:Connect(function()
    if isDraggingGui and dragInput then
        local delta = dragInput.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    if activeSlider then
        updateSliderFromX(activeSlider, UserInputService:GetMouseLocation().X)
    end
end)

-- =============================================
-- CORE LOGIC
-- =============================================
local function getTargetPlayer(searchString)
    if searchString == "" then return nil end
    searchString = searchString:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(searchString) or p.DisplayName:lower():find(searchString) then
            return p
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    if not hrp or not hrp.Parent or not isToggled or not playerSnapshotCFrame then return end
    local now = tick()
    if now - lastTeleportTime >= teleportDelay then
        lastTeleportTime = now
        if (hrp.Position - FIXED_TARGET_CFRAME.Position).Magnitude < 2 then
            task.wait(teleportBackDelay)
            hrp.CFrame = playerSnapshotCFrame
        else
            task.wait(teleportToDelay)
            hrp.CFrame = FIXED_TARGET_CFRAME
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if UserInputService:GetFocusedTextBox() then return end

    if input.KeyCode == Enum.KeyCode.L then
        mainFrame.Visible = not mainFrame.Visible
    end

    if input.KeyCode == Enum.KeyCode.C then
        isToggled = not isToggled
        TARGET_INPUT = textBox.Text
        if isToggled then
            local targetPlayer = getTargetPlayer(TARGET_INPUT)
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                playerSnapshotCFrame = targetPlayer.Character.HumanoidRootPart.CFrame
                statusLabel.Text = "LOCKED: " .. targetPlayer.DisplayName
                statusLabel.TextColor3 = Color3.new(0, 1, 0)
                -- Teleport instantly on activation
                hrp.CFrame = FIXED_TARGET_CFRAME
                lastTeleportTime = tick()
                task.spawn(function()
                    task.wait(grabStartDelay)
                    while isToggled do
                        pcall(function() GrabRemote:InvokeServer() end)
                        task.wait(grabLoopDelay)
                    end
                end)
            else
                statusLabel.Text = "No Target Found!"
                statusLabel.TextColor3 = Color3.new(1, 0, 0)
                isToggled = false
            end
        else
            playerSnapshotCFrame = nil
            statusLabel.Text = "Status: OFF  (Press C)"
            statusLabel.TextColor3 = Color3.new(1, 1, 1)
        end
    end
end)

player.CharacterAdded:Connect(function(newChar)
    character = newChar
    hrp = newChar:WaitForChild("HumanoidRootPart", 10)
end)
