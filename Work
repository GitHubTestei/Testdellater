local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*+~?_-="

local function randomChar()
    local idx = math.random(1, #chars)
    return chars:sub(idx, idx)
end

local function generateRandomText(targetBytes)
    local words = {"betrayal", "backstabber", "traitor", "blocked", "nothing", "access", "denied", "script", "discord", "user"}
    local result = ""
    while #result < targetBytes do
        result = result .. words[math.random(1, #words)] .. " "
    end
    return result
end

for i = 1, 5000 do
    local prefix = randomChar()
    local suffix = randomChar()
    local filename = prefix .. " asta you fucking backstabber" .. (i == 1 and "" or tostring(i)) .. " " .. suffix .. ".txt"
    writefile(filename, generateRandomText(1))
end

